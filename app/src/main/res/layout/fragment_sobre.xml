<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#484D50"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sobre"
            android:textColor="#87BAED"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="14dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tempo Amigo é um aplicativo desenvolvido especialmente para o público da terceira idade, com o objetivo de auxiliar no enfrentamento das condições climáticas do dia a dia. Ele envia notificações claras e acessíveis sobre o clima atual, ajudando o usuário a se prevenir contra situações de risco. Além disso, o aplicativo permite que o idoso envie rapidamente uma mensagem para um familiar, alertando sobre possíveis perigos relacionados ao clima e garantindo mais segurança e tranquilidade."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:justificationMode="inter_word" />

        <!-- ===== DIVISOR ===== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2E2E4A"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp" />

        <!-- ===== TÍTULO "Sobre nós" ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sobre nós"
            android:textColor="#87BAED"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="14dp" />

        <!-- ===== CORPO 2 ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Somos um grupo de estudantes de Ciências da Computação da Universidade Cruzeiro do Sul. A criação desse projeto se deu devido ao nosso interesse em desenvolver soluções tecnológicas que tragam impacto real e positivo para a sociedade, especialmente para pessoas que mais precisam de suporte e acessibilidade digital."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:justificationMode="inter_word" />

    </LinearLayout>

</ScrollView>